# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/ledger"

# ── Docker Compose ────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Upstash ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
