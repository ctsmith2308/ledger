// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["identity", "banking", "transactions", "transactions_read", "budgets", "events", "shared"]
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  tier         String        @default("TRIAL")
  mfaEnabled   Boolean       @default(false) @map("mfa_enabled")
  mfaSecret    String?       @map("mfa_secret")
  createdAt    DateTime      @default(now()) @map("created_at")
  profile      UserProfile?
  sessions     UserSession[]

  @@schema("identity")
  @@map("users")
}

model UserSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String    @default("TRIAL")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@schema("identity")
  @@map("user_sessions")
}

model UserProfile {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  timezone  String?  @default("America/Denver")
  currency  String?  @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@schema("identity")
  @@map("user_profiles")
}

// ─── Banking Context ────────────────────────────────────────────────

model PlaidItem {
  id            String        @id @map("plaid_item_id")
  userId        String        @map("user_id")
  accessToken   String        @map("access_token")
  institutionId String?       @map("institution_id")
  cursor        String?
  createdAt     DateTime      @default(now()) @map("created_at")
  bankAccounts  BankAccount[]

  @@index([userId])
  @@schema("banking")
  @@map("plaid_items")
}

model BankAccount {
  id               String    @id @map("plaid_account_id")
  plaidItemId      String    @map("plaid_item_id")
  plaidItem        PlaidItem @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  name             String
  officialName     String?   @map("official_name")
  mask             String?
  type             String
  subtype          String?
  availableBalance Decimal?  @map("available_balance") @db.Decimal(12, 2)
  currentBalance   Decimal?  @map("current_balance") @db.Decimal(12, 2)
  currencyCode     String?   @default("USD") @map("currency_code")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([plaidItemId])
  @@schema("banking")
  @@map("bank_accounts")
}

// ─── Transactions Context ───────────────────────────────────────────

model Transaction {
  id               String   @id @map("plaid_transaction_id")
  accountId        String   @map("account_id")
  userId           String   @map("user_id")
  amount           Decimal  @db.Decimal(12, 2)
  date             DateTime @db.Date
  name             String
  merchantName     String?  @map("merchant_name")
  category         String?
  detailedCategory String?  @map("detailed_category")
  pending          Boolean  @default(false)
  paymentChannel   String?  @map("payment_channel")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([accountId])
  @@index([userId, category])
  @@schema("transactions")
  @@map("transactions")
}

// ─── Transactions Read Model ────────────────────────────────────────

model CategoryRollup {
  id               String @id @default(uuid())
  userId           String @map("user_id")
  category         String
  period           String // "2026-03"
  totalCents       Int    @map("total_cents")
  transactionCount Int    @map("transaction_count")

  @@unique([userId, category, period])
  @@index([userId, period])
  @@schema("transactions_read")
  @@map("category_rollups")
}

// ─── Budgets Context ────────────────────────────────────────────────

model Budget {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  category     String
  monthlyLimit Decimal  @map("monthly_limit") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, category])
  @@index([userId])
  @@schema("budgets")
  @@map("budgets")
}

// ─── Event Store ────────────────────────────────────────────────────

model DomainEventRecord {
  id          String    @id @default(uuid())
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  payload     Json
  status      String    @default("pending") // "pending" | "processed" | "failed"
  attempts    Int       @default(0)
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([eventType, status])
  @@index([aggregateId])
  @@index([createdAt])
  @@schema("events")
  @@map("domain_events")
}

// ─── Shared ─────────────────────────────────────────────────────────

model FeatureFlag {
  id      String  @id @default(uuid())
  tier    String
  feature String
  enabled Boolean @default(true)

  @@unique([tier, feature])
  @@schema("shared")
  @@map("feature_flags")
}

